#!/usr/bin/env bash
set -euo pipefail

source "{{ control_node_runtime_runtime_env_path }}"

export HOME="/home/{{ control_node_runtime_run_user }}"
export PATH="${VENV_DIR}/bin:${HOME}/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

cd "${REPO_DIR}"

cmd=( "${VENV_DIR}/bin/ansible-playbook" )
inventory_explicit=false

for arg in "$@"; do
  if [[ "${arg}" == "-i" || "${arg}" == "--inventory" ]]; then
    inventory_explicit=true
    break
  fi
done

if [[ "${inventory_explicit}" == "false" && -n "${INVENTORY_PATH:-}" ]]; then
  cmd+=( "-i" "${INVENTORY_PATH}" )
fi

cmd+=( "$@" )

exec "${cmd[@]}"
