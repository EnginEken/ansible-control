extends: default

ignore: |
  .venv/
  collections/ansible_collections/

rules:
  braces:
    max-spaces-inside: 1
  brackets:
    max-spaces-inside: 1
  comments-indentation: disable
  document-start: disable
  line-length:
    max: 160
    level: warning
  truthy:
    allowed-values:
      - "true"
      - "false"
    check-keys: false
